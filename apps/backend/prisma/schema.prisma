generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  SUPER_ADMIN
  REGIONAL_MANAGER
  BRANCH_MANAGER
  ADMIN
  RECEPTIONIST
  TRAINER
  MEMBER
}

enum MembershipPlan {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum NotificationType {
  MEMBERSHIP_RENEWAL
  PAYMENT_REMINDER
  ATTENDANCE_REMINDER
  DIET_PLAN_UPDATED
  WORKOUT_PLAN_UPDATED
  GENERAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  CHECK_IN
}

enum DueStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum BadgeType {
  ATTENDANCE
  STREAK
  GOAL
  PROGRESS
  SPECIAL
}

enum ProgressPhotoType {
  BEFORE
  PROGRESS
  AFTER
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  MOBILITY
  WARMUP
  STRETCHING
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  CORE
  FULL_BODY
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
}

enum MessageType {
  TEXT
  PROGRESS_COMMENT
  FEEDBACK
}

enum FeedbackRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL_BOOKED
  TRIAL_COMPLETED
  NEGOTIATION
  CONVERTED
  LOST
}

enum LeadSource {
  WALK_IN
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  CALL
  OTHER
}

enum CampaignType {
  PROMOTIONAL
  REFERRAL
  REACTIVATION
  WHATSAPP
}

enum ChallengeType {
  ATTENDANCE
  WORKOUT
  WEIGHT_LOSS
  CONSISTENCY
  CUSTOM
}

enum ChallengeStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MissionType {
  CHECK_IN
  COMPLETE_WORKOUT
  LOG_PROGRESS
  FOLLOW_DIET
  SEND_FEEDBACK
}

enum RewardType {
  XP
  BADGE
  DISCOUNT
  GIFT
}

enum CommunityGroupType {
  FITNESS
  WEIGHT_LOSS
  BODYBUILDING
  YOGA
  CROSSFIT
  RUNNING
  CUSTOM
}

enum SaaSPlanInterval {
  MONTHLY
  YEARLY
}

enum GymSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum SaaSInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  FAILED
  CANCELLED
}

enum MarketplaceItemType {
  TRAINER
  DIET_PLAN
  WORKOUT_TEMPLATE
}

enum MarketplaceItemStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum WebhookEvent {
  MEMBER_CREATED
  PAYMENT_RECEIVED
  SUBSCRIPTION_UPDATED
  LEAD_CREATED
  MARKETPLACE_PURCHASED
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
}

//////////////////////////////////////////////////////
// GYM (TENANT)
//////////////////////////////////////////////////////

model Gym {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  phone    String?
  address  String?
  logo     String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
  dues          Due[]

  bodyMeasurements BodyMeasurement[]
  goals Goal[]
  memberBadges MemberBadge[]
  progressPhotos ProgressPhoto[]

  users         User[]
  members       Member[]
  memberships   Membership[]
  attendances   Attendance[]
  dietPlans     DietPlan[]
  workoutPlans  WorkoutPlan[]
  notifications Notification[]
  payments      Payment[]

  exercises Exercise[]
  leads Lead[]
  campaigns Campaign[]
  communityGroups CommunityGroup[]

  workoutCompletions WorkoutCompletion[]
  
  trainerMessages TrainerMessage[]
  trainerFeedbacks TrainerFeedback[]

  challenges Challenge[]
  memberXps MemberXP[]
  dailyMissions DailyMission[]
  rewards Reward[]

  branches Branch[]
  regionalManagerBranches RegionalManagerBranch[]

  subscriptions GymSubscription[]
  saasInvoices SaaSInvoice[]

  whiteLabelSetting WhiteLabelSetting?

  marketplaceItems MarketplaceItem[]

  apiKeys ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  integrations Integration[]

}

//////////////////////////////////////////////////////
// USERS (ALL ROLES)
//////////////////////////////////////////////////////

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  role         Role    @default(MEMBER)
  isActive     Boolean @default(true)

  gymId String?
  gym   Gym?    @relation(fields: [gymId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
  sessions Session[]
  
  deviceTokens DeviceToken[]
  deviceSessions DeviceSession[]

  // relations
  memberProfile Member?

  assignedLeads Lead[]
  campaigns Campaign[]

  // trainer → members mapping
  trainedMembers Member[] @relation("TrainerMembers")

  trainerWorkoutPlans WorkoutPlan[] @relation("TrainerWorkoutPlans")

  trainerMessages TrainerMessage[] @relation("TrainerMessages")
  sentMessages TrainerMessage[] @relation("MessageSender")
  trainerFeedbacks TrainerFeedback[] @relation("TrainerFeedbacks")

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])
  regionalBranches RegionalManagerBranch[]
  marketplaceItems MarketplaceItem[]
}

//////////////////////////////////////////////////////
// MEMBER PROFILE
//////////////////////////////////////////////////////

model Member {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  phone       String
  gender      String?
  dateOfBirth DateTime?
  address     String?

  height      Float?
  weight      Float?
  fitnessGoal String?

  trainerId String?
  trainer   User?   @relation("TrainerMembers", fields: [trainerId], references: [id])
  
  bodyMeasurements BodyMeasurement[]
  goals Goal[]
  memberBadges MemberBadge[]
  progressPhotos ProgressPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dues          Due[]

  workoutPlans WorkoutPlan[]
  communityGroups CommunityGroupMember[]

  challengeParticipants ChallengeParticipant[]
  memberXp MemberXP?
  missionCompletions MissionCompletion[]

  memberships   Membership[]
  attendances   Attendance[]
  dietPlan      DietPlan?
  notifications Notification[]
  payments      Payment[]

  workoutCompletions WorkoutCompletion[]

  trainerMessages TrainerMessage[]
  trainerFeedbacks TrainerFeedback[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])
}

//////////////////////////////////////////////////////
// MEMBERSHIP / BILLING
//////////////////////////////////////////////////////

model Membership {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  plan          MembershipPlan
  startDate     DateTime
  endDate       DateTime
  amount        Float
  paymentStatus PaymentStatus  @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dues          Due[]
}

//////////////////////////////////////////////////////
// ATTENDANCE
//////////////////////////////////////////////////////

model Attendance {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  checkInAt DateTime @default(now())
  date      DateTime

  createdAt DateTime @default(now())

  @@unique([gymId, memberId, date])
}

//////////////////////////////////////////////////////
// DIET PLAN
//////////////////////////////////////////////////////

model DietPlan {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id])

  goal  String?
  notes String?

  meals DietMeal[]

  monday    String?
  tuesday   String?
  wednesday String?
  thursday  String?
  friday    String?
  saturday  String?
  sunday    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// WORKOUT PLAN
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  type    NotificationType
  title   String
  message String

  isSent Boolean   @default(false)
  sentAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

model Payment {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  amount Float
  method String // UPI, CASH, CARD, etc
  status PaymentStatus
  paidAt DateTime      @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Session {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  deviceName       String?
  ipAddress        String?
  userAgent        String?

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Due {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  amount     Float
  paidAmount Float @default(0)
  balance    Float

  status DueStatus @default(PENDING)

  dueDate DateTime
  paidAt  DateTime?

  reminderCount Int       @default(0)
  lastReminderAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([membershipId])
  @@index([status])
  @@index([dueDate])
}

model DeviceToken {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  token    String @unique
  platform String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BodyMeasurement {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  weight Float?

  chest Float?
  waist Float?
  hips Float?
  arms Float?
  thighs Float?

  bodyFatPercentage Float?

  bmi Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
}

model Goal {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  title String

  description String?

  targetValue Float?

  currentValue Float?

  unit String?

  startDate DateTime
  targetDate DateTime?

  status GoalStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
}

model Badge {
  id String @id @default(uuid())

  name        String
  description String?
  type        BadgeType
  icon        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberBadges MemberBadge[]
}

model MemberBadge {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([memberId, badgeId])
  @@index([gymId])
  @@index([memberId])
}

model ProgressPhoto {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  imageUrl String
  type     ProgressPhotoType @default(PROGRESS)

  notes String?

  takenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([takenAt])
}

model Exercise {
  id              String              @id @default(uuid())
  gymId           String?
  name            String
  description     String?
  category        ExerciseCategory
  muscleGroup     MuscleGroup
  difficulty      DifficultyLevel
  equipment       String?
  instructions    String?
  videoUrl        String?
  imageUrl        String?
  caloriesBurned  Int?
  durationMinutes Int?
  isPublic        Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym Gym? @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([muscleGroup])
  @@index([difficulty])

  workoutExercises WorkoutExercise[]
}

model WorkoutPlan {
  id          String   @id @default(uuid())
  gymId       String
  trainerId   String
  memberId    String?
  title       String
  description String?
  difficulty  DifficultyLevel
  durationWeeks Int?
  isTemplate  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym      Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer  User     @relation("TrainerWorkoutPlans", fields: [trainerId], references: [id], onDelete: Cascade)
  member   Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  exercises WorkoutExercise[]

  completions WorkoutCompletion[]

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model WorkoutExercise {
  id            String @id @default(uuid())
  workoutPlanId String
  exerciseId    String

  dayNumber Int
  sets      Int
  reps      String
  restSeconds Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
   
  completions WorkoutCompletion[]

  @@index([workoutPlanId])
  @@index([exerciseId])
}

model WorkoutCompletion {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  workoutExerciseId String?
  workoutExercise   WorkoutExercise? @relation(fields: [workoutExerciseId], references: [id], onDelete: SetNull)

  dayNumber Int?

  completedAt DateTime @default(now())
  notes       String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([memberId])
  @@index([workoutPlanId])
}

model DietMeal {
  id String @id @default(uuid())

  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  dayOfWeek String
  mealType  MealType

  title       String
  description String?
  calories    Int?
  protein     Float?
  carbs       Float?
  fats        Float?

  time String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dietPlanId])
  @@index([dayOfWeek])
  @@index([mealType])
}

model TrainerMessage {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   User @relation("TrainerMessages", fields: [trainerId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  senderId String
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  type    MessageType @default(TEXT)
  message String

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
  @@index([senderId])
}

model TrainerFeedback {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   User @relation("TrainerFeedbacks", fields: [trainerId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  rating  FeedbackRating
  comment String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model Lead {
  id             String      @id @default(cuid())
  gymId          String
  gym            Gym         @relation(fields: [gymId], references: [id])

  assignedToId   String?
  assignedTo     User?       @relation(fields: [assignedToId], references: [id])

  name           String
  phone          String
  email          String?

  source         LeadSource
  status         LeadStatus  @default(NEW)

  fitnessGoal    String?
  notes          String?

  trialDate      DateTime?
  followUpDate   DateTime?

  convertedAt    DateTime?
  lostReason     String?

  leadScore      Int         @default(0)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Campaign {
  id            String        @id @default(cuid())

  gymId         String
  gym           Gym           @relation(fields: [gymId], references: [id])

  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])

  type          CampaignType

  title         String
  message       String

  targetCount   Int           @default(0)
  sentCount     Int           @default(0)

  scheduledAt   DateTime?
  sentAt        DateTime?

  isActive      Boolean       @default(true)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Branch {
  id            String      @id @default(cuid())

  gymId         String
  gym           Gym         @relation(fields: [gymId], references: [id])

  name          String
  code          String      @unique

  phone         String?
  email         String?

  address       String?
  city          String?
  state         String?
  country       String?

  isActive      Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  users         User[]
  members       Member[]
  regionalManagers RegionalManagerBranch[]
}

model RegionalManagerBranch {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  managerId String
  manager   User @relation(fields: [managerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  @@unique([managerId, branchId])
}

model Challenge {
  id          String @id @default(cuid())
  gymId       String
  gym         Gym    @relation(fields: [gymId], references: [id])

  title       String
  description String?
  type        ChallengeType
  status      ChallengeStatus @default(UPCOMING)

  targetValue Int?
  startDate   DateTime
  endDate     DateTime

  participants ChallengeParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([status])
}

model ChallengeParticipant {
  id String @id @default(cuid())

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  progress Int @default(0)
  rank     Int?
  isCompleted Boolean @default(false)

  joinedAt DateTime @default(now())

  @@unique([challengeId, memberId])
  @@index([memberId])
}

model MemberXP {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  xp Int @default(0)
  level Int @default(1)
  streak Int @default(0)

  updatedAt DateTime @updatedAt
}

model DailyMission {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  title String
  description String?
  type MissionType
  xpReward Int @default(10)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions MissionCompletion[]
}

model MissionCompletion {
  id String @id @default(cuid())

  missionId String
  mission   DailyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())

  @@unique([missionId, memberId, completedAt])
  @@index([memberId])
}

model Reward {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  title String
  description String?
  type RewardType
  xpCost Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityGroup {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  name String
  description String?

  type CommunityGroupType

  isPrivate Boolean @default(false)

  members CommunityGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
}

model CommunityGroupMember {
  id String @id @default(cuid())

  groupId String
  group   CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([groupId, memberId])
}

model SaaSPlan {
  id String @id @default(cuid())

  name String
  description String?

  interval SaaSPlanInterval
  price Float

  maxBranches Int?
  maxMembers Int?
  maxStaff Int?

  isActive Boolean @default(true)

  subscriptions GymSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GymSubscription {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  planId String
  plan   SaaSPlan @relation(fields: [planId], references: [id])

  status GymSubscriptionStatus @default(TRIALING)

  startDate DateTime
  endDate DateTime

  autoRenew Boolean @default(true)

  invoices SaaSInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([planId])
  @@index([status])
}

model SaaSInvoice {
  id String @id @default(cuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  subscriptionId String
  subscription   GymSubscription @relation(fields: [subscriptionId], references: [id])

  invoiceNumber String @unique

  amount Float
  gstAmount Float
  totalAmount Float

  status SaaSInvoiceStatus @default(ISSUED)

  dueDate DateTime
  paidAt DateTime?
  failedAt DateTime?

  retryCount Int @default(0)
  lastRetryAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([subscriptionId])
  @@index([status])
}

