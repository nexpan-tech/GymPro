model AuditLog {
  id          String   @id @default(cuid())
  gymId       String?
  userId      String?

  action AuditAction

  entityType  String?
  entityId    String?

  method      String?  @default("UNKNOWN")
  path        String?  @default("UNKNOWN")

  ipAddress   String?
  userAgent   String?
  metadata    Json?

  createdAt   DateTime @default(now())

  gym         Gym?     @relation(fields: [gymId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([gymId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}