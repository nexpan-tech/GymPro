generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  SUPER_ADMIN
  REGIONAL_MANAGER
  BRANCH_MANAGER
  ADMIN
  RECEPTIONIST
  TRAINER
  MEMBER
}

enum MembershipPlan {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  FROZEN
  CANCELLED
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}

enum AttendanceSource {
  QR
  MANUAL
  ADMIN
}

enum NotificationType {
  MEMBERSHIP_RENEWAL
  PAYMENT_REMINDER
  ATTENDANCE_REMINDER
  DIET_PLAN_UPDATED
  WORKOUT_PLAN_UPDATED
  GENERAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  CHECK_IN
}

enum DueStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum BadgeType {
  ATTENDANCE
  STREAK
  GOAL
  PROGRESS
  SPECIAL
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  MOBILITY
  WARMUP
  STRETCHING
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  CORE
  FULL_BODY
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
}

enum MessageType {
  TEXT
  PROGRESS_COMMENT
  FEEDBACK
}

enum FeedbackRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  TRIAL
  TRIAL_BOOKED
  TRIAL_COMPLETED
  NEGOTIATION
  CONVERTED
  LOST
}

// Stage 7 — retention/churn risk band stored on Member.
enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Stage 7 — CRM lead activity / follow-up history.
enum LeadActivityType {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  MEETING
  STATUS_CHANGE
  FOLLOW_UP
  TRIAL_STARTED
  CONVERSION
}

// Stage 7 — trial membership lifecycle.
enum TrialStatus {
  ACTIVE
  EXPIRED
  CONVERTED
  CANCELLED
}

enum LeadSource {
  WALK_IN
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  CALL
  OTHER
}

enum CampaignType {
  PROMOTIONAL
  REFERRAL
  REACTIVATION
  WHATSAPP
}

enum ChallengeType {
  ATTENDANCE
  WORKOUT
  WEIGHT_LOSS
  CONSISTENCY
  CUSTOM
}

enum ChallengeStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MissionType {
  CHECK_IN
  COMPLETE_WORKOUT
  LOG_PROGRESS
  FOLLOW_DIET
  SEND_FEEDBACK
}

enum RewardType {
  XP
  BADGE
  DISCOUNT
  GIFT
}

enum CommunityGroupType {
  FITNESS
  WEIGHT_LOSS
  BODYBUILDING
  YOGA
  CROSSFIT
  RUNNING
  CUSTOM
}

enum SaaSPlanInterval {
  MONTHLY
  YEARLY
}

enum GymSubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum SaaSInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  FAILED
  CANCELLED
}

enum MarketplaceItemType {
  TRAINER
  DIET_PLAN
  WORKOUT_TEMPLATE
}

enum MarketplaceItemStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum WebhookEvent {
  MEMBER_CREATED
  PAYMENT_RECEIVED
  SUBSCRIPTION_UPDATED
  LEAD_CREATED
  MARKETPLACE_PURCHASED
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
}

//////////////////////////////////////////////////////
// GYM (TENANT)
//////////////////////////////////////////////////////

model Gym {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  phone    String?
  address  String?
  logo     String?
  isActive Boolean @default(true)

  // Stage 6 — GST / invoicing config. stateCode drives CGST+SGST (intra-state)
  // vs IGST (inter-state) splits on member invoices.
  gstNumber String?
  gstPercent Float  @default(18)
  stateCode  String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
  dues      Due[]
  invoices  Invoice[]

  bodyMeasurements BodyMeasurement[]
  goals            Goal[]
  memberBadges     MemberBadge[]

  users           User[]
  members         Member[]
  memberships     Membership[]
  membershipPlans GymMembershipPlan[]
  attendances     Attendance[]
  dietPlans       DietPlan[]
  workoutPlans    WorkoutPlan[]
  notifications   Notification[]
  payments        Payment[]

  exercises       Exercise[]
  leads           Lead[]
  leadActivities  LeadActivity[]
  trialMemberships TrialMembership[]
  campaigns       Campaign[]
  communityGroups CommunityGroup[]

  workoutCompletions WorkoutCompletion[]
  dietCompletions    DietCompletion[]

  trainerMessages  TrainerMessage[]
  trainerFeedbacks TrainerFeedback[]

  challenges    Challenge[]
  memberXps     MemberXP[]
  dailyMissions DailyMission[]
  rewards       Reward[]

  branches                Branch[]
  regionalManagerBranches RegionalManagerBranch[]

  subscriptions GymSubscription[]
  saasInvoices  SaaSInvoice[]

  whiteLabelSetting WhiteLabelSetting?

  marketplaceItems MarketplaceItem[]

  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  integrations     Integration[]
}

//////////////////////////////////////////////////////
// USERS (ALL ROLES)
//////////////////////////////////////////////////////

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  role         Role    @default(MEMBER)
  isActive     Boolean @default(true)

  gymId String?
  gym   Gym?    @relation(fields: [gymId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]
  sessions  Session[]

  deviceTokens   DeviceToken[]
  deviceSessions DeviceSession[]

  // relations
  memberProfile Member?

  assignedLeads Lead[]
  leadActivities LeadActivity[] @relation("LeadActivityAuthor")
  campaigns     Campaign[]

  // trainer → members mapping
  trainedMembers Member[] @relation("TrainerMembers")

  recordedMeasurements BodyMeasurement[] @relation("RecordedMeasurements")

  trainerWorkoutPlans WorkoutPlan[] @relation("TrainerWorkoutPlans")

  trainerMessages  TrainerMessage[]  @relation("TrainerMessages")
  sentMessages     TrainerMessage[]  @relation("MessageSender")
  trainerFeedbacks TrainerFeedback[] @relation("TrainerFeedbacks")

  branchId         String?
  branch           Branch?                 @relation(fields: [branchId], references: [id])
  regionalBranches RegionalManagerBranch[]
  marketplaceItems MarketplaceItem[]
}

//////////////////////////////////////////////////////
// MEMBER PROFILE
//////////////////////////////////////////////////////

model Member {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  phone       String
  gender      String?
  dateOfBirth DateTime?
  address     String?

  height      Float?
  weight      Float?
  fitnessGoal String?

  // Stage 2 — lifecycle + health profile
  status   MemberStatus @default(ACTIVE)
  joinedAt DateTime     @default(now())

  emergencyContactName  String?
  emergencyContactPhone String?
  healthNotes           String?
  injuryNotes           String?
  medicalConditions     String?

  trainerId String?
  trainer   User?   @relation("TrainerMembers", fields: [trainerId], references: [id])

  bodyMeasurements BodyMeasurement[]
  goals            Goal[]
  memberBadges     MemberBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dues      Due[]

  workoutPlans    WorkoutPlan[]
  communityGroups CommunityGroupMember[]

  challengeParticipants ChallengeParticipant[]
  memberXp              MemberXP?
  missionCompletions    MissionCompletion[]

  memberships   Membership[]
  attendances   Attendance[]
  dietPlan      DietPlan?
  notifications Notification[]
  payments      Payment[]
  invoices      Invoice[]

  workoutCompletions WorkoutCompletion[]
  dietCompletions    DietCompletion[]

  trainerMessages  TrainerMessage[]
  trainerFeedbacks TrainerFeedback[]

  // Stage 7 — persisted retention/churn scoring (recomputed by a nightly job).
  retentionScore Int?
  riskScore      Int?
  riskLevel      RiskLevel?
  scoredAt       DateTime?

  trialMemberships TrialMembership[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])
}

//////////////////////////////////////////////////////
// MEMBERSHIP / BILLING
//////////////////////////////////////////////////////

model Membership {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  // Legacy enum kept for backward compatibility; new memberships reference a
  // GymMembershipPlan via planId.
  plan    MembershipPlan?
  planId  String?
  planRef GymMembershipPlan? @relation(fields: [planId], references: [id])

  startDate     DateTime
  endDate       DateTime
  amount        Float
  paymentStatus PaymentStatus @default(PENDING)

  // Stage 2 — lifecycle
  status          MembershipStatus @default(ACTIVE)
  freezeStartDate DateTime?
  freezeEndDate   DateTime?
  extensionDays   Int              @default(0)

  // Renewal chain (self relation)
  renewedFromId String?
  renewedFrom   Membership?  @relation("MembershipRenewals", fields: [renewedFromId], references: [id])
  renewals      Membership[] @relation("MembershipRenewals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dues      Due[]
  payments  Payment[]
  invoices  Invoice[]

  @@index([gymId])
  @@index([memberId])
}

//////////////////////////////////////////////////////
// GYM MEMBERSHIP PLANS (named, priced, per-gym)
//////////////////////////////////////////////////////

model GymMembershipPlan {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  name         String
  description  String?
  durationDays Int
  price        Float
  isActive     Boolean @default(true)

  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
}

//////////////////////////////////////////////////////
// ATTENDANCE
//////////////////////////////////////////////////////

model Attendance {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  checkInAt  DateTime  @default(now())
  checkOutAt DateTime?
  date       DateTime

  status AttendanceStatus @default(CHECKED_IN)
  source AttendanceSource @default(QR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@unique([gymId, memberId, date])
  @@index([gymId, date])
  @@index([gymId, status])
}

//////////////////////////////////////////////////////
// DIET PLAN
//////////////////////////////////////////////////////

model DietPlan {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id])

  goal  String?
  notes String?

  meals       DietMeal[]
  completions DietCompletion[]

  monday    String?
  tuesday   String?
  wednesday String?
  thursday  String?
  friday    String?
  saturday  String?
  sunday    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// WORKOUT PLAN
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  type    NotificationType
  title   String
  message String

  isSent Boolean   @default(false)
  sentAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

model Payment {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  // Optional links so a payment can settle a membership and/or a recorded due.
  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  amount Float
  method String // UPI, CASH, CARD, RAZORPAY, etc
  status PaymentStatus
  paidAt DateTime      @default(now())

  // Stage 6 — gateway reconciliation (Razorpay/Stripe). Null for manual/cash.
  gateway         String? // RAZORPAY | STRIPE | MANUAL
  gatewayOrderId  String?
  gatewayPaymentId String?

  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([membershipId])
}

// ── Member invoices (Gym → Member) with GST. Metadata only (no PDF). ─────────
model Invoice {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  // One invoice per payment (when a payment generated it).
  paymentId String? @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  invoiceNumber String   @unique
  invoiceDate   DateTime @default(now())

  customerName String
  customerGST  String?

  subtotal    Float
  gstPercent  Float @default(0)
  cgst        Float @default(0)
  sgst        Float @default(0)
  igst        Float @default(0)
  gstAmount   Float @default(0)
  totalAmount Float

  status InvoiceStatus @default(ISSUED)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([status])
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  deviceName       String?
  ipAddress        String?
  userAgent        String?

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Due {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  amount     Float
  paidAmount Float @default(0)
  balance    Float

  status DueStatus @default(PENDING)

  dueDate DateTime
  paidAt  DateTime?

  reminderCount  Int       @default(0)
  lastReminderAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([membershipId])
  @@index([status])
  @@index([dueDate])
}

model DeviceToken {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token    String @unique
  platform String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BodyMeasurement {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // Who recorded this entry (member self, trainer, or admin). Nullable for
  // legacy rows created before this field existed.
  recordedById String?
  recordedBy   User?   @relation("RecordedMeasurements", fields: [recordedById], references: [id], onDelete: SetNull)

  // Effective date of the measurement (can be back-dated); createdAt is the
  // insert time. Timeline/charts order by recordedAt.
  recordedAt DateTime @default(now())

  weight Float?
  height Float?

  chest  Float?
  waist  Float?
  hips   Float?
  arms   Float?
  thighs Float?

  bodyFatPercentage Float?
  muscleMass        Float?

  bmi Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([recordedAt])
}

model Goal {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  title String

  description String?

  // Optional metric key (e.g. "weight", "bodyFatPercentage", "waist") this goal
  // tracks, enabling goal-progress % against a body metric.
  metric String?

  startValue   Float?
  targetValue  Float?
  currentValue Float?

  unit String?

  startDate  DateTime
  targetDate DateTime?

  status GoalStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
}

model Badge {
  id String @id @default(uuid())

  name        String
  description String?
  type        BadgeType
  icon        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberBadges MemberBadge[]
}

model MemberBadge {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([memberId, badgeId])
  @@index([gymId])
  @@index([memberId])
}

model Exercise {
  id              String           @id @default(uuid())
  gymId           String?
  name            String
  description     String?
  category        ExerciseCategory
  muscleGroup     MuscleGroup
  difficulty      DifficultyLevel
  equipment       String?
  instructions    String?
  videoUrl        String?
  imageUrl        String?
  caloriesBurned  Int?
  durationMinutes Int?
  isPublic        Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym Gym? @relation(fields: [gymId], references: [id], onDelete: Cascade)

  workoutExercises WorkoutExercise[]

  @@index([category])
  @@index([muscleGroup])
  @@index([difficulty])
}

model WorkoutPlan {
  id            String          @id @default(uuid())
  gymId         String
  trainerId     String
  memberId      String?
  title         String
  description   String?
  difficulty    DifficultyLevel
  durationWeeks Int?
  isTemplate    Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym     Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer User    @relation("TrainerWorkoutPlans", fields: [trainerId], references: [id], onDelete: Cascade)
  member  Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  exercises WorkoutExercise[]

  completions WorkoutCompletion[]

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model WorkoutExercise {
  id            String @id @default(uuid())
  workoutPlanId String
  exerciseId    String

  dayNumber   Int
  sets        Int
  reps        String
  restSeconds Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  completions WorkoutCompletion[]

  @@index([workoutPlanId])
  @@index([exerciseId])
}

model WorkoutCompletion {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  workoutExerciseId String?
  workoutExercise   WorkoutExercise? @relation(fields: [workoutExerciseId], references: [id], onDelete: SetNull)

  dayNumber Int?

  completedAt DateTime @default(now())
  notes       String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([memberId])
  @@index([workoutPlanId])
}

model DietMeal {
  id String @id @default(uuid())

  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  dayOfWeek String
  mealType  MealType

  title       String
  description String?
  calories    Int?
  protein     Float?
  carbs       Float?
  fats        Float?

  time String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions DietCompletion[]

  @@index([dietPlanId])
  @@index([dayOfWeek])
  @@index([mealType])
}

model DietCompletion {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  dietMealId String?
  dietMeal   DietMeal? @relation(fields: [dietMealId], references: [id], onDelete: SetNull)

  dayOfWeek String?

  completedAt DateTime @default(now())
  notes       String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([memberId])
  @@index([dietPlanId])
}

model TrainerMessage {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   User   @relation("TrainerMessages", fields: [trainerId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  type    MessageType @default(TEXT)
  message String

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
  @@index([senderId])
}

model TrainerFeedback {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   User   @relation("TrainerFeedbacks", fields: [trainerId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  rating  FeedbackRating
  comment String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model Lead {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id])

  name  String
  phone String
  email String?

  source LeadSource
  status LeadStatus @default(NEW)

  fitnessGoal String?
  notes       String?

  trialDate    DateTime?
  followUpDate DateTime?

  convertedAt DateTime?
  lostReason  String?

  leadScore Int @default(0)

  // Stage 7 — CRM follow-up history + trial lifecycle
  activities LeadActivity[]
  trials     TrialMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([status])
}

// Stage 7 — chronological CRM activity / follow-up log for a lead.
model LeadActivity {
  id     String @id @default(cuid())
  gymId  String
  gym    Gym    @relation(fields: [gymId], references: [id])
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type LeadActivityType @default(NOTE)
  note String?

  // Stage transition captured on the activity, when relevant.
  fromStatus LeadStatus?
  toStatus   LeadStatus?

  createdById String?
  createdBy   User?   @relation("LeadActivityAuthor", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([leadId])
}

// Stage 7 — trial membership that can convert into a paid Membership.
model TrialMembership {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  // A trial may originate from a lead and/or be attached to a member profile.
  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id])
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  planId String?

  startDate DateTime  @default(now())
  endDate   DateTime
  status    TrialStatus @default(ACTIVE)

  // Conversion tracking
  convertedAt           DateTime?
  convertedMembershipId String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([status])
}

model Campaign {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  type CampaignType

  title   String
  message String

  targetCount Int @default(0)
  sentCount   Int @default(0)

  scheduledAt DateTime?
  sentAt      DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  name String
  code String @unique

  phone String?
  email String?

  address String?
  city    String?
  state   String?
  country String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  members          Member[]
  membershipPlans  GymMembershipPlan[]
  attendances      Attendance[]
  regionalManagers RegionalManagerBranch[]
}

model RegionalManagerBranch {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  managerId String
  manager   User   @relation(fields: [managerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  @@unique([managerId, branchId])
}

model Challenge {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  title       String
  description String?
  type        ChallengeType
  status      ChallengeStatus @default(UPCOMING)

  targetValue Int?
  startDate   DateTime
  endDate     DateTime

  participants ChallengeParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([status])
}

model ChallengeParticipant {
  id String @id @default(cuid())

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  progress    Int     @default(0)
  rank        Int?
  isCompleted Boolean @default(false)

  joinedAt DateTime @default(now())

  @@unique([challengeId, memberId])
  @@index([memberId])
}

model MemberXP {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  xp     Int @default(0)
  level  Int @default(1)
  streak Int @default(0)

  updatedAt DateTime @updatedAt
}

model DailyMission {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  title       String
  description String?
  type        MissionType
  xpReward    Int         @default(10)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions MissionCompletion[]
}

model MissionCompletion {
  id String @id @default(cuid())

  missionId String
  mission   DailyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())

  @@unique([missionId, memberId, completedAt])
  @@index([memberId])
}

model Reward {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  title       String
  description String?
  type        RewardType
  xpCost      Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityGroup {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  name        String
  description String?

  type CommunityGroupType

  isPrivate Boolean @default(false)

  members CommunityGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
}

model CommunityGroupMember {
  id String @id @default(cuid())

  groupId String
  group   CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([groupId, memberId])
}

model SaaSPlan {
  id String @id @default(cuid())

  name        String
  description String?

  interval SaaSPlanInterval
  price    Float

  maxBranches Int?
  maxMembers  Int?
  maxStaff    Int?

  isActive Boolean @default(true)

  subscriptions GymSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GymSubscription {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  planId String
  plan   SaaSPlan @relation(fields: [planId], references: [id])

  status GymSubscriptionStatus @default(TRIALING)

  startDate DateTime
  endDate   DateTime

  autoRenew Boolean @default(true)

  invoices SaaSInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([planId])
  @@index([status])
}

model SaaSInvoice {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  subscriptionId String
  subscription   GymSubscription @relation(fields: [subscriptionId], references: [id])

  invoiceNumber String @unique

  amount      Float
  gstAmount   Float
  totalAmount Float

  status SaaSInvoiceStatus @default(ISSUED)

  dueDate  DateTime
  paidAt   DateTime?
  failedAt DateTime?

  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([subscriptionId])
  @@index([status])
}

model WhiteLabelSetting {
  id String @id @default(cuid())

  gymId String @unique
  gym   Gym    @relation(fields: [gymId], references: [id])

  appName    String?
  logoUrl    String?
  faviconUrl String?

  primaryColor   String?
  secondaryColor String?
  accentColor    String?

  customDomain     String? @unique
  isDomainVerified Boolean @default(false)

  mobileAppName String?
  playStoreUrl  String?
  appStoreUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketplaceItem {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  type   MarketplaceItemType
  status MarketplaceItemStatus @default(DRAFT)

  title       String
  description String?
  price       Float   @default(0)

  imageUrl String?
  tags     String[]

  isFeatured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([type])
  @@index([status])
}

model ApiKey {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  name    String
  keyHash String @unique

  status ApiKeyStatus @default(ACTIVE)

  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([status])
}

model WebhookEndpoint {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  url    String
  events WebhookEvent[]

  secret String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
}

model Integration {
  id String @id @default(cuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  provider String
  status   IntegrationStatus @default(ACTIVE)

  config Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
}

model DeviceSession {
  id         String   @id @default(cuid())
  userId     String
  gymId      String?
  deviceId   String
  platform   String
  appVersion String?
  deviceName String?
  pushToken  String?
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([gymId])
  @@index([deviceId])
}

model AuditLog {
  id     String  @id @default(cuid())
  gymId  String?
  userId String?

  action AuditAction

  entityType String?
  entityId   String?

  method String? @default("UNKNOWN")
  path   String? @default("UNKNOWN")

  ipAddress String?
  userAgent String?
  metadata  Json?

  createdAt DateTime @default(now())

  gym  Gym?  @relation(fields: [gymId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([gymId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
