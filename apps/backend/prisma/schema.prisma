generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  SUPER_ADMIN
  ADMIN
  RECEPTIONIST
  TRAINER
  MEMBER
}

enum MembershipPlan {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum NotificationType {
  MEMBERSHIP_RENEWAL
  PAYMENT_REMINDER
  ATTENDANCE_REMINDER
  DIET_PLAN_UPDATED
  WORKOUT_PLAN_UPDATED
  GENERAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  CHECK_IN
}

enum DueStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum BadgeType {
  ATTENDANCE
  STREAK
  GOAL
  PROGRESS
  SPECIAL
}

enum ProgressPhotoType {
  BEFORE
  PROGRESS
  AFTER
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  MOBILITY
  WARMUP
  STRETCHING
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  CORE
  FULL_BODY
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
}

enum MessageType {
  TEXT
  PROGRESS_COMMENT
  FEEDBACK
}

enum FeedbackRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL_BOOKED
  TRIAL_COMPLETED
  NEGOTIATION
  CONVERTED
  LOST
}

enum LeadSource {
  WALK_IN
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  CALL
  OTHER
}

enum CampaignType {
  PROMOTIONAL
  REFERRAL
  REACTIVATION
  WHATSAPP
}
//////////////////////////////////////////////////////
// GYM (TENANT)
//////////////////////////////////////////////////////

model Gym {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  phone    String?
  address  String?
  logo     String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
  dues          Due[]

  bodyMeasurements BodyMeasurement[]
  goals Goal[]
  memberBadges MemberBadge[]
  progressPhotos ProgressPhoto[]

  users         User[]
  members       Member[]
  memberships   Membership[]
  attendances   Attendance[]
  dietPlans     DietPlan[]
  workoutPlans  WorkoutPlan[]
  notifications Notification[]
  payments      Payment[]

  exercises Exercise[]
  leads Lead[]
  campaigns Campaign[]

  workoutCompletions WorkoutCompletion[]
  
  trainerMessages TrainerMessage[]
  trainerFeedbacks TrainerFeedback[]
}

//////////////////////////////////////////////////////
// USERS (ALL ROLES)
//////////////////////////////////////////////////////

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String
  role         Role    @default(MEMBER)
  isActive     Boolean @default(true)

  gymId String?
  gym   Gym?    @relation(fields: [gymId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
  sessions Session[]
  
  deviceTokens DeviceToken[]
  
  // relations
  memberProfile Member?

  assignedLeads Lead[]
  campaigns Campaign[]

  // trainer → members mapping
  trainedMembers Member[] @relation("TrainerMembers")

  trainerWorkoutPlans WorkoutPlan[] @relation("TrainerWorkoutPlans")

  trainerMessages TrainerMessage[] @relation("TrainerMessages")
  sentMessages TrainerMessage[] @relation("MessageSender")
  trainerFeedbacks TrainerFeedback[] @relation("TrainerFeedbacks")
}

//////////////////////////////////////////////////////
// MEMBER PROFILE
//////////////////////////////////////////////////////

model Member {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  phone       String
  gender      String?
  dateOfBirth DateTime?
  address     String?

  height      Float?
  weight      Float?
  fitnessGoal String?

  trainerId String?
  trainer   User?   @relation("TrainerMembers", fields: [trainerId], references: [id])
  
  bodyMeasurements BodyMeasurement[]
  goals Goal[]
  memberBadges MemberBadge[]
  progressPhotos ProgressPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dues          Due[]

  workoutPlans WorkoutPlan[]

  memberships   Membership[]
  attendances   Attendance[]
  dietPlan      DietPlan?
  notifications Notification[]
  payments      Payment[]

  workoutCompletions WorkoutCompletion[]

  trainerMessages TrainerMessage[]
  trainerFeedbacks TrainerFeedback[]
}

//////////////////////////////////////////////////////
// MEMBERSHIP / BILLING
//////////////////////////////////////////////////////

model Membership {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  plan          MembershipPlan
  startDate     DateTime
  endDate       DateTime
  amount        Float
  paymentStatus PaymentStatus  @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dues          Due[]
}

//////////////////////////////////////////////////////
// ATTENDANCE
//////////////////////////////////////////////////////

model Attendance {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  checkInAt DateTime @default(now())
  date      DateTime

  createdAt DateTime @default(now())

  @@unique([gymId, memberId, date])
}

//////////////////////////////////////////////////////
// DIET PLAN
//////////////////////////////////////////////////////

model DietPlan {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id])

  goal  String?
  notes String?

  meals DietMeal[]

  monday    String?
  tuesday   String?
  wednesday String?
  thursday  String?
  friday    String?
  saturday  String?
  sunday    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// WORKOUT PLAN
//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id String @id @default(uuid())

  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  type    NotificationType
  title   String
  message String

  isSent Boolean   @default(false)
  sentAt DateTime?

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// PAYMENT
//////////////////////////////////////////////////////

model Payment {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  amount Float
  method String // UPI, CASH, CARD, etc
  status PaymentStatus
  paidAt DateTime      @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id String @id @default(uuid())

  gymId String?
  gym   Gym? @relation(fields: [gymId], references: [id])

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  action AuditAction
  entity String
  entityId String?

  oldData Json?
  newData Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  deviceName       String?
  ipAddress        String?
  userAgent        String?

  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Due {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  amount     Float
  paidAmount Float @default(0)
  balance    Float

  status DueStatus @default(PENDING)

  dueDate DateTime
  paidAt  DateTime?

  reminderCount Int       @default(0)
  lastReminderAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([membershipId])
  @@index([status])
  @@index([dueDate])
}

model DeviceToken {
  id String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  token    String @unique
  platform String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model BodyMeasurement {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  weight Float?

  chest Float?
  waist Float?
  hips Float?
  arms Float?
  thighs Float?

  bodyFatPercentage Float?

  bmi Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
}

model Goal {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  title String

  description String?

  targetValue Float?

  currentValue Float?

  unit String?

  startDate DateTime
  targetDate DateTime?

  status GoalStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
}

model Badge {
  id String @id @default(uuid())

  name        String
  description String?
  type        BadgeType
  icon        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberBadges MemberBadge[]
}

model MemberBadge {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([memberId, badgeId])
  @@index([gymId])
  @@index([memberId])
}

model ProgressPhoto {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  imageUrl String
  type     ProgressPhotoType @default(PROGRESS)

  notes String?

  takenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([memberId])
  @@index([takenAt])
}

model Exercise {
  id              String              @id @default(uuid())
  gymId           String?
  name            String
  description     String?
  category        ExerciseCategory
  muscleGroup     MuscleGroup
  difficulty      DifficultyLevel
  equipment       String?
  instructions    String?
  videoUrl        String?
  imageUrl        String?
  caloriesBurned  Int?
  durationMinutes Int?
  isPublic        Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym Gym? @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([muscleGroup])
  @@index([difficulty])

  workoutExercises WorkoutExercise[]
}

model WorkoutPlan {
  id          String   @id @default(uuid())
  gymId       String
  trainerId   String
  memberId    String?
  title       String
  description String?
  difficulty  DifficultyLevel
  durationWeeks Int?
  isTemplate  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym      Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer  User     @relation("TrainerWorkoutPlans", fields: [trainerId], references: [id], onDelete: Cascade)
  member   Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  exercises WorkoutExercise[]

  completions WorkoutCompletion[]

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model WorkoutExercise {
  id            String @id @default(uuid())
  workoutPlanId String
  exerciseId    String

  dayNumber Int
  sets      Int
  reps      String
  restSeconds Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
   
  completions WorkoutCompletion[]

  @@index([workoutPlanId])
  @@index([exerciseId])
}

model WorkoutCompletion {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  workoutPlanId String
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  workoutExerciseId String?
  workoutExercise   WorkoutExercise? @relation(fields: [workoutExerciseId], references: [id], onDelete: SetNull)

  dayNumber Int?

  completedAt DateTime @default(now())
  notes       String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([memberId])
  @@index([workoutPlanId])
}

model DietMeal {
  id String @id @default(uuid())

  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  dayOfWeek String
  mealType  MealType

  title       String
  description String?
  calories    Int?
  protein     Float?
  carbs       Float?
  fats        Float?

  time String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dietPlanId])
  @@index([dayOfWeek])
  @@index([mealType])
}

model TrainerMessage {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   User @relation("TrainerMessages", fields: [trainerId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  senderId String
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  type    MessageType @default(TEXT)
  message String

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
  @@index([senderId])
}

model TrainerFeedback {
  id String @id @default(uuid())

  gymId String
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerId String
  trainer   User @relation("TrainerFeedbacks", fields: [trainerId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  rating  FeedbackRating
  comment String?

  createdAt DateTime @default(now())

  @@index([gymId])
  @@index([trainerId])
  @@index([memberId])
}

model Lead {
  id             String      @id @default(cuid())
  gymId          String
  gym            Gym         @relation(fields: [gymId], references: [id])

  assignedToId   String?
  assignedTo     User?       @relation(fields: [assignedToId], references: [id])

  name           String
  phone          String
  email          String?

  source         LeadSource
  status         LeadStatus  @default(NEW)

  fitnessGoal    String?
  notes          String?

  trialDate      DateTime?
  followUpDate   DateTime?

  convertedAt    DateTime?
  lostReason     String?

  leadScore      Int         @default(0)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Campaign {
  id            String        @id @default(cuid())

  gymId         String
  gym           Gym           @relation(fields: [gymId], references: [id])

  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])

  type          CampaignType

  title         String
  message       String

  targetCount   Int           @default(0)
  sentCount     Int           @default(0)

  scheduledAt   DateTime?
  sentAt        DateTime?

  isActive      Boolean       @default(true)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}